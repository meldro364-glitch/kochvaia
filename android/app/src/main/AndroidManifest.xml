<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Camera is needed for kid-pairing QR scan and co-parent invite scan. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <!-- Android 13+ requires runtime permission to post notifications. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Haptic confirmation when the parent taps a notification action. -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:name=".KochvaiaApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:isGame="false"
        android:theme="@style/Theme.Kochvaia">

        <!-- Tells Fire OS this app is safe to surface in the Amazon Kids
             profile picker. Without it, sideloaded apps are filtered out
             of the "Add Content → Apps" list on Fire HD Kids tablets. -->
        <meta-data
            android:name="amazon.support.freetime"
            android:value="true" />
        <meta-data
            android:name="amazon.kindle.kids"
            android:value="true" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Kochvaia">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- QR pairing deep link: kochvaia://join?code=XXXX-YYYY -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="kochvaia" android:host="join" />
            </intent-filter>
        </activity>

        <!-- Inline "⭐ <Name>" action button on the daily reminder routes here. -->
        <receiver
            android:name=".notify.StarActionReceiver"
            android:exported="false" />

        <!-- Debug-only: adb broadcast triggers an instant ReminderWorker run.
             Exported so adb can reach it; gated by BuildConfig.DEBUG inside. -->
        <receiver
            android:name=".notify.DebugReminderReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.kochvaia.app.debug.TRIGGER_REMINDER" />
            </intent-filter>
        </receiver>

        <!-- We provide a Configuration via KochvaiaApp (HiltWorkerFactory),
             so disable the default startup-driven WorkManager initializer. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
    </application>
</manifest>
